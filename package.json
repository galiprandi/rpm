{
  "name": "rpm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:debug": "DEBUG_AUTH_ENABLED=true next dev",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "start:debug": "DEBUG_AUTH_ENABLED=true next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev --port 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:all": "vitest run --config vitest.all.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:setup": "docker-compose up -d postgres && sleep 3 && prisma migrate dev",
    "db:migrate": "prisma migrate dev",
    "db:reset": "docker-compose down -v && docker-compose up -d postgres && sleep 3 && prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "deploy": "vercel --prod"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.51",
    "@ai-sdk/react": "^3.0.151",
    "@better-auth/prisma-adapter": "^1.5.6",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.4",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^6.0.149",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "prisma": "^7.5.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^8.10.1",
    "react-dom": "19.2.4",
    "react-markdown": "^9.0.1",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "storybook": "^10.3.3",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "vite": "7.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.1.1",
    "@vitest/ui": "^4.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
}
