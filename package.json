{
  "name": "rpm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:debug": "DEBUG_AUTH_ENABLED=true next dev",
    "build": "npx prisma generate && next build --webpack",
    "vercel-build": "npx prisma generate && npx prisma migrate deploy && next build --webpack",
    "start": "next start",
    "start:debug": "DEBUG_AUTH_ENABLED=true next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:all": "vitest run --config vitest.all.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:setup": "docker-compose up -d postgres && sleep 3 && npx prisma migrate dev",
    "db:migrate": "npx prisma migrate dev",
    "db:reset": "docker-compose down -v && docker-compose up -d postgres && sleep 3 && npx prisma migrate dev",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "deploy": "vercel --prod"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.5.6",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.6.0",
    "next": "16.2.6",
    "pg": "^8.20.0",
    "postcss": "^8.5.13",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.2",
      "kysely": "0.28.17"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@prisma/client": "6.19.3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sharp": "^0.32.0",
    "@vitest/coverage-v8": "4.1.1",
    "@vitest/ui": "^4.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@10.4.1"
}
