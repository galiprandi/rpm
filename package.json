{
  "name": "rpm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma migrate deploy && next build",
    "start": "next start",
    "storybook": "npx storybook dev --port 6006",
    "build-storybook": "npx storybook build",
    "lint": "eslint",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "test:e2e": "playwright test --reporter=line",
    "test:e2e:ci": "playwright test --reporter=line",
    "test:e2e:dev": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:codegen": "playwright codegen",
    "test:visual": "chromatic --exit-zero-on-changes",
    "test:all": "pnpm test:unit && pnpm test:e2e",
    "db:start": "docker-compose up -d postgres",
    "db:stop": "docker-compose down",
    "db:reset": "docker-compose down -v && docker-compose up -d postgres",
    "db:logs": "docker-compose logs postgres",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy",
    "db:seed": "npx prisma db seed",
    "deploy": "./scripts/deploy-with-db.sh",
    "deploy:prod": "vercel --prod",
    "db:setup": "./scripts/setup-db-env.sh",
    "db:health": "curl http://localhost:3000/api/health/db",
    "db:health:prod": "curl https://rpm-wheat.vercel.app/api/health/db",
    "db:validate": "npx tsx scripts/validate-db.ts",
    "db:urls": "./scripts/get-db-urls.sh",
    "db:setup-auth": "psql $DATABASE_URL -f scripts/setup-auth-tables.sql"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.5.6",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-mcp": "^0.4.2",
    "@storybook/react-vite": "^10.3.3",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "storybook": "^10.3.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.1.1",
    "@vitest/ui": "^4.1.1",
    "chromatic": "^16.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
}
