{
  "name": "rpm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "TZ=UTC next dev",
    "dev:debug": "TZ=UTC RPM_DEV_BYPASS_AUTH=true next dev",
    "build": "next build --webpack",
    "vercel-build": "next build --webpack",
    "start": "next start",
    "start:debug": "RPM_DEV_BYPASS_AUTH=true next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:all": "vitest run --config vitest.all.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "npx drizzle-kit migrate",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "npx drizzle-kit studio",
    "db:generate": "npx drizzle-kit generate",
    "db:push": "npx drizzle-kit push",
    "deploy": "vercel --prod",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.16",
    "@ai-sdk/groq": "^4.0.11",
    "@ai-sdk/react": "4.0.20",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^7.0.19",
    "better-auth": "^1.6.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dayjs": "^1.11.21",
    "dotenv": "^17.3.1",
    "drizzle-orm": "0.45.2",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.6.0",
    "next": "16.2.11",
    "pg": "^8.20.0",
    "pino": "^9.0.0",
    "postcss": "^8.5.13",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "sharp": "$sharp",
    "postcss": "$postcss"
  },
  "pnpm": {
    "overrides": {
      "dompurify": ">=3.4.5",
      "fast-uri": ">=3.1.2",
      "kysely": "0.28.17",
      "esbuild": "0.28.1",
      "vite": "8.0.16",
      "hono": ">=4.12.25",
      "undici": ">=7.28.0 <8.0.0",
      "sharp": ">=0.35.3",
      "postcss": ">=8.5.12"
    },
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sharp": "^0.32.0",
    "@vitest/coverage-v8": "4.1.1",
    "@vitest/ui": "^4.1.1",
    "drizzle-kit": "0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "eslint --fix"
  },
  "packageManager": "pnpm@10.4.1",
  "browserslist": [
    "Chrome >= 107",
    "Firefox >= 107",
    "Safari >= 15.4",
    "Edge >= 107"
  ]
}