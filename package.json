{
  "name": "rpm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:debug": "DEBUG_AUTH_ENABLED=true next dev",
    "build": "npx prisma generate && next build",
    "build:local": "npx prisma migrate deploy && next build",
    "start": "next start",
    "start:debug": "DEBUG_AUTH_ENABLED=true next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "storybook": "npx storybook dev --port 6006",
    "build-storybook": "npx storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy",
    "db:seed": "npx prisma db seed",
    "db:start": "docker-compose up -d postgres",
    "db:stop": "docker-compose down",
    "db:reset": "docker-compose down -v && docker-compose up -d postgres",
    "db:reset:prod": "node scripts/reset-db-prod.js",
    "deploy": "vercel --prod"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.51",
    "@ai-sdk/react": "^3.0.151",
    "@better-auth/prisma-adapter": "^1.5.6",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-mcp": "^0.4.2",
    "@storybook/react-vite": "^10.3.3",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^6.0.149",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "storybook": "^10.3.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "7.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.1.1",
    "@vitest/ui": "^4.1.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.1"
  }
}
