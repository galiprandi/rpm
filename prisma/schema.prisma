generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model category {
  id                   String    @id
  name                 String    @unique
  description          String?
  defaultMarginPercent Float     @default(40)
  color                String?
  sortOrder            Int       @default(0)
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime
  product              product[]

  @@index([sortOrder])
}

model customer {
  id           String        @id @default(cuid())
  phone        String?
  phoneAlt     String?
  email        String?
  address      String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime
  billingData  Json?
  name         String
  balance      Decimal       @default(0) @db.Decimal(10, 2)
  credit_notes credit_note[]
  direct_sales direct_sale[]
  invoices     invoice[]
  vehicle      vehicle[]
  work_order   work_order[]

  @@index([name])
  @@index([phone])
  @@index([balance])
}

model photo {
  id          String     @id
  workOrderId String
  type        String
  url         String
  description String?
  createdAt   DateTime   @default(now())
  work_order  work_order @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([workOrderId])
}

model price_list {
  id                   String            @id
  name                 String
  isPublic             Boolean           @default(false)
  isActive             Boolean           @default(true)
  startDate            DateTime?
  endDate              DateTime?
  baseMarginPercentage Decimal           @db.Decimal(5, 2)
  roundingRule         String            @default("SMART_HUNDREDS")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime
  price_list_item      price_list_item[]

  @@index([isActive])
  @@index([isPublic])
}

model price_list_item {
  id                       String     @id
  priceListId              String
  productId                String?
  overrideMarginPercentage Decimal?   @db.Decimal(5, 2)
  fixedPrice               Decimal?   @db.Decimal(10, 2)
  createdAt                DateTime   @default(now())
  updatedAt                DateTime
  price_list               price_list @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product                  product?   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId])
  @@index([priceListId])
  @@index([productId])
}

model product {
  id                String             @id
  sku               String?            @unique
  name              String
  description       String?
  costPrice         Decimal            @db.Decimal(10, 2)
  stock             Int                @default(0)
  minStock          Int                @default(0)
  barcode           String?
  location          String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime
  categoryId        String
  supplierId        String?
  lastMovementAt    DateTime?
  replacementCost        Decimal                  @db.Decimal(10, 2)
  imageBranch            String?                  @default("main")
  imageCommit            String?
  imageUrl               String?
  lastCountedAt          DateTime?
  credit_note_items      credit_note_item[]
  direct_sale_items      direct_sale_item[]
  price_list_item        price_list_item[]
  inventory_count_items  inventory_count_item[]
  purchase_voucher_item  purchase_voucher_item[]
  category               category                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  supplier               supplier?                @relation(fields: [supplierId], references: [id])
  stock_movement         stock_movement[]
  work_order_item        work_order_item[]

  @@index([categoryId])
  @@index([isActive])
  @@index([imageUrl])
  @@index([lastMovementAt])
  @@index([name])
  @@index([sku])
  @@index([stock, minStock])
  @@index([supplierId])
}

model service {
  id                String             @id
  name              String             @unique
  description       String?
  baseCost          Decimal            @db.Decimal(10, 2)
  timeMinutes       Int                @default(60)
  vehicleFactor     Decimal            @default(1.0) @db.Decimal(3, 2)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime
  credit_note_items credit_note_item[]
  direct_sale_items direct_sale_item[]
  work_order_item   work_order_item[]

  @@index([isActive])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model setting {
  id        String   @id
  key       String   @unique
  value     String
  updatedAt DateTime
}

model stock_movement {
  id            String   @id
  productId     String
  userId        String?
  userName      String?
  type          String
  quantity      Int
  previousStock Int
  newStock      Int
  reason        String
  reasonDetails String?
  salePrice     Decimal? @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  product       product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([productId])
  @@index([type])
}

model supplier {
  id                String             @id
  name              String             @unique
  cuit              String?            // CUIT/CUIL del proveedor (opcional)
  contactName       String?
  phone             String?
  email             String?
  address           String?
  notes             String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime
  product           product[]
  purchase_voucher  purchase_voucher[]

  @@index([isActive])
  @@index([name])
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  role          String    @default("USER")
  account       Account[]
  session       Session[]

  @@map("user")
}

model user_role {
  id        String    @id
  email     String    @unique
  role      String
  name      String?
  notes     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime
  lastLogin DateTime?
  image     String?

  @@index([email])
  @@index([role])
}

model vehicle {
  id            String         @id
  identifier    String
  category      String
  makeId        String?
  modelId       String?
  year          Int?
  color         String?
  equipmentName String?
  equipmentType String?
  description   String?
  notes         String?
  customerId    String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  customer      customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle_make  vehicle_make?  @relation(fields: [makeId], references: [id])
  vehicle_model vehicle_model? @relation(fields: [modelId], references: [id])
  work_order    work_order[]

  @@unique([identifier, customerId])
  @@index([category])
  @@index([customerId])
  @@index([identifier])
}

model vehicle_make {
  id             String          @id
  name           String
  normalizedName String          @unique
  category       String[]
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  vehicle        vehicle[]
  vehicle_model  vehicle_model[]

  @@index([normalizedName])
}

model vehicle_model {
  id             String       @id
  makeId         String
  name           String
  normalizedName String
  years          Int[]
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  vehicle        vehicle[]
  vehicle_make   vehicle_make @relation(fields: [makeId], references: [id], onDelete: Cascade)

  @@unique([makeId, normalizedName])
  @@index([makeId])
  @@index([normalizedName])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  @@index([identifier])
  @@map("verification")
}

model work_order {
  id              String                 @id
  status          String
  customerId      String
  vehicleId       String
  technicianId    String?
  entryChecklist  Json?
  exitChecklist   Json?
  entryPhotos     String[]
  exitPhotos      String[]
  scheduledDate   DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  deliveredAt     DateTime?
  paymentMethod   String?
  paymentNotes    String?
  total           Decimal                @db.Decimal(10, 2)
  totalProducts   Decimal                @db.Decimal(10, 2)
  totalServices   Decimal                @db.Decimal(10, 2)
  invoiceId       String?
  notes           String
  createdAt       DateTime               @default(now())
  updatedAt       DateTime
  source          String                 @default("IN_PERSON")
  fuelLevel       Int?
  odometerValue   Int?
  payments        payment[]
  photo           photo[]
  customer        customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle         vehicle                @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  auditLogs       work_order_audit_log[]
  work_order_item work_order_item[]

  @@index([createdAt])
  @@index([customerId])
  @@index([scheduledDate])
  @@index([status])
  @@index([technicianId])
  @@index([vehicleId])
}

model work_order_audit_log {
  id          String     @id @default(uuid())
  workOrderId String
  fieldName   String
  oldValue    String?
  newValue    String?
  changedBy   String
  changedAt   DateTime   @default(now())
  ipAddress   String?
  userAgent   String?
  work_order  work_order @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([changedAt])
  @@index([fieldName])
  @@index([changedBy])
}

model work_order_item {
  id            String     @id
  workOrderId   String
  type          String
  productId     String?
  serviceId     String?
  quantity      Int
  unitPrice     Decimal    @db.Decimal(10, 2)
  subtotal      Decimal    @db.Decimal(10, 2)
  isManualPrice Boolean    @default(false)
  priceListId   String?
  product       product?   @relation(fields: [productId], references: [id])
  service       service?   @relation(fields: [serviceId], references: [id])
  work_order    work_order @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([serviceId])
  @@index([workOrderId])
}

model cost_update_batch {
  id              String   @id @default(uuid())
  userId          String
  userName        String?
  filtersApplied  Json
  adjustmentType  String
  adjustmentValue Decimal  @db.Decimal(10, 2)
  itemsAffected   Int
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@map("cost_update_batch")
}

model payment_method {
  id                 String                @id @default(cuid())
  name               String                @unique
  code               String                @unique
  description        String?
  isActive           Boolean               @default(true)
  sortOrder          Int                   @default(0)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime
  directSalePayments direct_sale_payment[]
  payments           payment[]
  creditNotes        credit_note[]
  purchase_voucher   purchase_voucher[]

  @@index([isActive])
  @@index([sortOrder])
}

model payment {
  id              String         @id @default(cuid())
  workOrderId     String
  paymentMethodId String
  amount          Decimal        @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime       @default(now())
  createdBy       String
  paymentMethod   payment_method @relation(fields: [paymentMethodId], references: [id])
  workOrder       work_order     @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([paymentMethodId])
}

model direct_sale {
  id           String                @id @default(cuid())
  customerId   String?
  customerName String
  total        Decimal               @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime              @default(now())
  createdBy    String
  customer     customer?             @relation(fields: [customerId], references: [id])
  items        direct_sale_item[]
  payments     direct_sale_payment[]

  @@index([customerId])
  @@index([createdAt])
}

model direct_sale_item {
  id           String      @id @default(cuid())
  directSaleId String
  productId    String?
  serviceId    String?
  name         String
  quantity     Int
  unitPrice    Decimal     @db.Decimal(10, 2)
  totalPrice   Decimal     @db.Decimal(10, 2)
  directSale   direct_sale @relation(fields: [directSaleId], references: [id], onDelete: Cascade)
  product      product?    @relation(fields: [productId], references: [id])
  service      service?    @relation(fields: [serviceId], references: [id])

  @@index([directSaleId])
  @@index([productId])
  @@index([serviceId])
}

model direct_sale_payment {
  id              String         @id @default(cuid())
  directSaleId    String
  paymentMethodId String
  amount          Decimal        @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime       @default(now())
  createdBy       String
  directSale      direct_sale    @relation(fields: [directSaleId], references: [id], onDelete: Cascade)
  paymentMethod   payment_method @relation(fields: [paymentMethodId], references: [id])

  @@index([directSaleId])
  @@index([paymentMethodId])
}

model cash_movement {
  id            String   @id @default(cuid())
  type          String
  amount        Decimal  @db.Decimal(10, 2)
  method        String
  referenceId   String?
  referenceType String?
  reason        String?
  notes         String?
  createdAt     DateTime @default(now())
  createdBy     String
  responsibleId String?

  @@index([type])
  @@index([createdAt])
  @@index([referenceId])
  @@index([responsibleId])
}

model invoice {
  id            String       @id @default(cuid())
  number        String       @unique
  type          String
  referenceId   String
  referenceType String
  customerId    String?
  customerName  String
  customerDoc     String?
  customerDocType String?
  subtotal      Decimal      @db.Decimal(10, 2)
  tax           Decimal?     @db.Decimal(10, 2)
  iva21         Decimal?     @db.Decimal(10, 2)
  iva105        Decimal?     @db.Decimal(10, 2)
  exemptions    Json?
  perceptions   Json?
  total         Decimal      @db.Decimal(10, 2)
  afipData      Json?
  status        String
  issuedAt      DateTime?
  createdAt     DateTime     @default(now())
  createdBy     String
  customer      customer?    @relation(fields: [customerId], references: [id])

  @@index([number])
  @@index([referenceId])
  @@index([status])
  @@index([type])
  @@index([issuedAt])
}

model credit_note {
  id               String             @id @default(cuid())
  originalSaleId   String
  originalSaleType String
  customerId       String
  total            Decimal            @db.Decimal(10, 2)
  refundMethod     String             // 'CASH' | 'ACCOUNT_CREDIT'
  paymentMethodId  String?
  status           String             @default("ISSUED") // 'ISSUED' | 'CANCELLED'
  notes            String?
  createdAt        DateTime           @default(now())
  createdBy        String
  customer         customer           @relation(fields: [customerId], references: [id])
  paymentMethod    payment_method?    @relation(fields: [paymentMethodId], references: [id])
  items            credit_note_item[]

  @@index([customerId])
  @@index([originalSaleId, originalSaleType])
  @@index([paymentMethodId])
  @@index([status])
  @@map("credit_note")
}

model credit_note_item {
  id           String      @id @default(cuid())
  creditNoteId String
  productId    String?
  serviceId    String?
  name         String
  quantity     Int
  unitPrice    Decimal     @db.Decimal(10, 2)
  totalPrice   Decimal     @db.Decimal(10, 2)
  creditNote   credit_note @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  product      product?    @relation(fields: [productId], references: [id])
  service      service?    @relation(fields: [serviceId], references: [id])

  @@index([creditNoteId])
  @@index([productId])
  @@index([serviceId])
  @@map("credit_note_item")
}

model inventory_count_operative {
  id            String                 @id @default(cuid())
  status        String                 @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, APPROVED, CANCELLED
  itemCount     Int
  createdBy     String
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  finishedAt    DateTime?
  approvedAt    DateTime?
  approvedBy    String?
  items         inventory_count_item[]

  @@index([status])
  @@index([createdAt])
  @@map("inventory_count_operative")
}

model inventory_count_item {
  id                  String                    @id @default(cuid())
  operativeId         String
  productId           String
  theoreticalStock    Int
  countedStock        Int?
  previousLocation    String?
  newLocation         String?
  isFound             Boolean                   @default(false)
  reportedAt          DateTime?
  reportedBy          String?
  operative           inventory_count_operative @relation(fields: [operativeId], references: [id], onDelete: Cascade)
  product             product                   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([operativeId])
  @@index([productId])
  @@map("inventory_count_item")
}

// ============================================
// Comprobantes de Compra
// ============================================

model purchase_voucher {
  id              String                  @id @default(cuid())
  supplierId      String
  letter          String                  // Letra del comprobante (texto libre: A, B, C, etc.)
  number          String                  // Número de la factura física
  date            DateTime                // Fecha del comprobante físico
  totalAmount     Decimal                 @db.Decimal(10, 2) // Monto total declarado de la factura
  paymentMethodId String?                 // null = Cuenta Corriente (no genera mov. de caja)
  notes           String?
  status          String                  @default("DRAFT") // 'DRAFT' | 'FINALIZED'
  createdBy       String
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  finalizedAt     DateTime?
  supplier        supplier                @relation(fields: [supplierId], references: [id])
  paymentMethod   payment_method?         @relation(fields: [paymentMethodId], references: [id])
  items           purchase_voucher_item[]

  @@unique([supplierId, letter, number])
  @@index([status])
  @@index([supplierId])
  @@index([createdAt])
}

model purchase_voucher_item {
  id              String           @id @default(cuid())
  voucherId       String
  productId       String
  productName     String           // Snapshot del nombre al momento de carga
  quantity        Int
  unitCost        Decimal          @db.Decimal(10, 2)
  subtotal        Decimal          @db.Decimal(10, 2)
  priceListData   Json?            // Precios calculados/fijos por lista: { [priceListId]: { price: number, isFixed: boolean } }
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  voucher         purchase_voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  product         product          @relation(fields: [productId], references: [id])

  @@unique([voucherId, productId]) // Un producto no puede aparecer dos veces en el mismo comprobante
  @@index([voucherId])
  @@index([productId])
}
