# Environment Variables Example
# Copy this to .env.local and fill with your values

# Better Auth Configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=your-secret-key-min-32-chars
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Public URL for client-side
NEXT_PUBLIC_URL=http://localhost:3000

# Database Configuration
# Development (Docker PostgreSQL)
DATABASE_URL="..."

# Admin Emails (comma-separated)
# These emails automatically get ADMIN role on login, bypassing database check
# Useful for first setup or recovery when seed hasn't run
ADMIN_EMAILS=admin@example.com,superuser@company.com

# Production (Vercel Postgres)
# These will be configured automatically by Vercel
# Do not set these locally

# Debug Auth - Solo para desarrollo local
# Habilita bypass de autenticación Google OAuth para tests y desarrollo
# Nunca usar en producción
DEBUG_AUTH_ENABLED=false
DEBUG_AUTH_DEFAULT_ROLE=USER  # USER | STAFF | ADMIN

# Product Images Configuration
# Sistema de almacenamiento de imágenes de productos usando GitHub + jsDelivr CDN
# Spec: /specs/spec-product-images.md
PRODUCT_IMAGES_REPO=galiprandi/rpm-product-images
PRODUCT_IMAGES_BRANCH=main
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
PRODUCT_IMAGE_MAX_WIDTH=500
PRODUCT_IMAGE_MAX_HEIGHT=500
PRODUCT_IMAGE_QUALITY=85
PRODUCT_IMAGE_FORMAT=jpeg
