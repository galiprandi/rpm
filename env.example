# =============================================================================
# REQUIRED - App will fail to start if these are missing
# =============================================================================

# 🗄️ Database (PostgreSQL)
DATABASE_URL="postgresql://user:pass@localhost:5432/rpm"

# =============================================================================
# OPTIONAL - App works without these (uses defaults)
# =============================================================================

# 🖼️ Images (GitHub for product uploads)
PRODUCT_IMAGES_REPO=rpmsysadim/images
PRODUCT_IMAGES_TOKEN=ghp_xxxxxxxxxxxx
PRODUCT_IMAGE_MAX_WIDTH=500
PRODUCT_IMAGE_MAX_HEIGHT=500
PRODUCT_IMAGE_QUALITY=85
PRODUCT_IMAGE_FORMAT=jpeg
PRODUCT_IMAGES_BRANCH=develop  # Branch for image uploads (develop/main)

# 🔑 Auth (Better Auth + Google OAuth)
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=your-secret-key-min-32-chars
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 🧪 Debug Auth (dev only - bypasses Google OAuth)
# Activa sesión mock automática sin OAuth. Solo funciona en NODE_ENV=development.
RPM_DEV_BYPASS_AUTH=false
RPM_DEV_BYPASS_ROLE=ADMIN       # USER | STAFF | ADMIN
RPM_DEV_BYPASS_USER_ID=dev-user
RPM_DEV_BYPASS_NAME=Developer
RPM_DEV_BYPASS_EMAIL=dev@localhost

# � Admin auto-assign (comma-separated emails)
ADMIN_EMAILS=admin@example.com

# 🤖 Bot / AI (Groq - primary, Google Gemini - fallback)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# 🌐 Public URL (defaults to localhost)
NEXT_PUBLIC_URL=http://localhost:3000

# 📦 GitHub CDN Service (future unified bucket - falls back to PRODUCT_IMAGES_REPO)
GITHUB_CDN_REPO=rpmsysadim/statics
GITHUB_CDN_BRANCH=main
